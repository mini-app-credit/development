# deployment.env — Environment-specific, non-sensitive configuration
# Copy to deployment/deployment.env and fill in values.

# Project
PROJECT_NAME=mini-credit
NODE_ENV=development

# Domain routing
DOMAIN_NAME=mini-credit.local
FRONTEND_DOMAIN=app.${DOMAIN_NAME}
API_DOMAIN=api.${DOMAIN_NAME}
TEMPLATES_DOMAIN=templates.${DOMAIN_NAME}
STORAGE_DOMAIN=storage.${DOMAIN_NAME}

# Database
POSTGRES_USER=postgres
POSTGRES_DB=minicredit

# Sentry
SENTRY_ENVIRONMENT=development

# SMTP
SMTP_HOST=mini-credit-mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_FROM=noreply@mini-credit.local

# Channels OAuth (client IDs are not secrets)
OAUTH_INSTAGRAM_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_YOUTUBE_CLIENT_ID=263433568346-hamuq6d439ortr1ln89m3610s0hqeker.apps.googleusercontent.com
OAUTH_LINKEDIN_CLIENT_ID=
