# sensitive.env — Secrets and credentials
# Copy to deployment/sensitive.env and fill in values.
# NEVER commit this file to git.

# Database (use literal host mini-credit-postgres in Docker; Compose does not reliably expand ${VAR} from other env_file lines)
POSTGRES_PASSWORD=postgres
DATABASE_WRITE_URL=postgresql://postgres:postgres@mini-credit-postgres:5432/minicredit
DATABASE_READ_REPLICA_URLS=postgresql://postgres:postgres@mini-credit-postgres:5432/minicredit

# AWS (S3 — IAM user or keys with access to S3_BUCKET_NAME)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# JWT
JWT_SECRET=dev-jwt-secret

# Frontend
FRONTEND_COOKIE_SECRET=dev-cookie-secret

# Channels OAuth (secrets)
CREDENTIALS_ENCRYPTION_KEY=dev-encryption-key-32-chars-long!
OAUTH_INSTAGRAM_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_YOUTUBE_CLIENT_SECRET=
OAUTH_LINKEDIN_CLIENT_SECRET=

# Internal API Token (scheduler → API)
INTERNAL_API_TOKEN=dev-internal-token

# Google Gemini (optional — overrides vendor.env if set)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3-flash-preview

# SMTP
SMTP_PASSWORD=
