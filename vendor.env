# vendor.env — Static defaults (versioned, same across all environments)
# These rarely change and are safe to commit to git.

# Application
NAME=mini-credit
LEVEL=debug

# Internal service hostnames (Docker DNS)
REDIS_HOST=mini-credit-redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TLS=false
# S3: use real AWS bucket + credentials in deployment/sensitive.env
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_BUCKET_NAME=minicredit-documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false
TEMPLATES_SERVICE_URL=http://mini-credit-templates:3100

# Service ports
API_PORT=3000
FRONTEND_PORT=4000
TEMPLATES_PORT=3100

# JWT
JWT_EXPIRES_IN=15m

# Rate Limiting
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX_REQUESTS=100
RATE_LIMIT_AUTH_SENSITIVE_WINDOW_MS=60000
RATE_LIMIT_AUTH_SENSITIVE_MAX_REQUESTS=10
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=60000
RATE_LIMIT_AUTHENTICATED_MAX_REQUESTS=300

# Sentry (defaults — override in deployment.env)
SENTRY_DSN=
SENTRY_RELEASE=0.0.1
SENTRY_SEND_DEFAULT_PII=true
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_DEBUG=false
SENTRY_ENABLED=false

# Amplitude
AMPLITUDE_API_KEY=

# Google Gemini — AI advisory summary (loaded by Docker for mini-credit-api; override in deployment/sensitive.env if needed)
GEMINI_API_KEY=AIzaSyBHjC5Z1zhX9tHs4JFqUExzGVDF3JbmCkk
GEMINI_MODEL=gemini-3-flash-preview

# SMTP defaults
SMTP_HOST=mini-credit-mailpit
SMTP_PORT=1025
SMTP_SECURE=false
